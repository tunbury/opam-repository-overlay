opam-version: "2.0"
synopsis: "S3 client for OCaml using Eio"
description: """
A minimal Amazon S3 / Ceph RGW compatible client built on Eio and cohttp-eio.
Supports streaming uploads and downloads of large objects (single PUT or
multipart, auto-selected), object metadata, and AWS Signature Version 4
request signing.
"""
maintainer: "mark.elvers@tunbury.org"
authors: "mark.elvers@tunbury.org"
license: "MIT"
depends: [
  "ocaml" {>= "5.1.0"}
  "dune" {>= "3.0"}
  "eio" {>= "1.0"}
  "eio_main"
  "cohttp-eio" {>= "6.0.0"}
  "cohttp"
  "http"
  "uri"
  "digestif"
  "xmlm"
  "fmt"
  "logs"
  "cmdliner" {>= "1.1.0"}
  "tls-eio" {>= "0.17.0"}
  "ca-certs"
  "x509"
  "domain-name"
  "ptime"
  "mirage-crypto-rng"
  "alcotest" {with-test}
]
build: [
  ["dune" "build" "-p" name "-j" jobs]
  ["dune" "runtest" "-p" name "-j" jobs] {with-test}
]

url {
  src: "git+https://github.com/mtelvers/ocaml-s3#0f038b7c1806bdc90bb5329466488d561ab4c76d"
}
