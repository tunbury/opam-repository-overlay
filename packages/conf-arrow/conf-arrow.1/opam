opam-version: "2.0"
maintainer: "Mark Elvers <mark@tarides.com>"
authors: ["Apache Arrow contributors"]
homepage: "https://arrow.apache.org/"
bug-reports: "https://github.com/ocaml/opam-repository/issues"
license: "Apache-2.0"
build: [
  ["sh" "-exc" """
    set -eu
    sudo apt-get install -y -V ca-certificates lsb-release wget
    distro=$(lsb_release --id --short | tr '[:upper:]' '[:lower:]')
    codename=$(lsb_release --codename --short)
    deb=apache-arrow-apt-source-latest-${codename}.deb
    wget -q https://packages.apache.org/artifactory/arrow/${distro}/${deb}
    sudo apt-get install -y -V ./${deb}
    rm -f ${deb}
    sudo apt-get update
    sudo apt-get install -y -V libarrow-dev libparquet-dev
    pkg-config --exists parquet
  """] {os-family = "debian" | os-family = "ubuntu"}
  ["pkg-config" "--exists" "parquet"]
    {os-family != "debian" & os-family != "ubuntu"}
]
depends: ["conf-pkg-config" {build}]
depexts: [
  ["libarrow-devel" "libparquet-libs-devel"] {os-family = "fedora"}
  ["libarrow-devel" "libparquet-devel"] {os-family = "suse" | os-family = "opensuse"}
  ["apache-arrow-dev"] {os-distribution = "alpine"}
  ["arrow"] {os-family = "arch" | os-family = "archlinux"}
  ["apache-arrow"] {os = "freebsd"}
  ["apache-arrow"] {os = "macos" & os-distribution = "homebrew"}
]
synopsis: "Virtual package relying on an Apache Arrow system installation"
description:
  "This package can only install if the Apache Arrow C++ and Parquet libraries are installed on the system. On Debian and Ubuntu the Apache Arrow APT repository is configured automatically and libarrow-dev and libparquet-dev are installed from it."
flags: conf
